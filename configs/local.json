{
  "cluster": {
    "backend": "local",
    "workspace_root": "runs",
    "archive_root": "/tmp/archives",
    "default_container_image": "ghcr.io/kalowery/codeswarm-local-worker:latest",
    "default_container_pull_policy": "if_not_present",
    "claude_env_profiles": {
      "amd-llm-gateway": {
        "ANTHROPIC_API_KEY": "dummy",
        "ANTHROPIC_BASE_URL": "https://llm-api.amd.com/Anthropic",
        "ANTHROPIC_CUSTOM_HEADERS": "Ocp-Apim-Subscription-Key: ${LLM_GATEWAY_KEY}",
        "ANTHROPIC_MODEL": "Claude-Sonnet-4.5",
        "ANTHROPIC_DEFAULT_OPUS_MODEL": "Claude-Opus-4.5",
        "ANTHROPIC_DEFAULT_SONNET_MODEL": "Claude-Sonnet-4.5",
        "ANTHROPIC_DEFAULT_HAIKU_MODEL": "Claude-Haiku-4.5",
        "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
      }
    }
  },
  "model_pricing": {
    "gpt-5.4": {
      "input_tokens_usd_per_m": 2.5,
      "cached_input_tokens_usd_per_m": 0.25,
      "output_tokens_usd_per_m": 15.0,
      "reasoning_output_tokens_usd_per_m": 0.0
    },
    "Claude-Sonnet-4.5": {
      "input_tokens_usd_per_m": 3.0,
      "cached_input_tokens_usd_per_m": 0.3,
      "output_tokens_usd_per_m": 15.0,
      "reasoning_output_tokens_usd_per_m": 0.0
    },
    "Claude-Opus-4.5": {
      "input_tokens_usd_per_m": 15.0,
      "cached_input_tokens_usd_per_m": 1.5,
      "output_tokens_usd_per_m": 75.0,
      "reasoning_output_tokens_usd_per_m": 0.0
    },
    "Claude-Haiku-4.5": {
      "input_tokens_usd_per_m": 1.0,
      "cached_input_tokens_usd_per_m": 0.1,
      "output_tokens_usd_per_m": 5.0,
      "reasoning_output_tokens_usd_per_m": 0.0
    }
  },
  "launch_providers": [
    {
      "id": "local-dev",
      "label": "Local Dev",
      "backend": "local",
      "defaults": {
        "worker_mode": "codex",
        "approval_policy": "never",
        "sandbox_mode": "danger-full-access",
        "native_auto_approve": false,
        "fresh_thread_per_injection": false,
        "claude_env_profile": "amd-llm-gateway"
      }
    },
    {
      "id": "local-orchestrated-planner",
      "label": "Local Orchestrated Planner",
      "backend": "local",
      "defaults": {
        "worker_mode": "codex",
        "approval_policy": "never",
        "sandbox_mode": "danger-full-access",
        "native_auto_approve": true,
        "fresh_thread_per_injection": false,
        "claude_env_profile": "amd-llm-gateway"
      }
    },
    {
      "id": "local-orchestrated-worker",
      "label": "Local Orchestrated Worker",
      "backend": "local",
      "defaults": {
        "worker_mode": "codex",
        "approval_policy": "never",
        "sandbox_mode": "danger-full-access",
        "native_auto_approve": true,
        "fresh_thread_per_injection": false,
        "claude_env_profile": "amd-llm-gateway"
      }
    },
    {
      "id": "local-mock-worker",
      "label": "Local Mock Worker",
      "backend": "local",
      "defaults": {
        "worker_mode": "mock",
        "approval_policy": "never",
        "sandbox_mode": "danger-full-access",
        "native_auto_approve": false,
        "fresh_thread_per_injection": false,
        "claude_env_profile": "amd-llm-gateway"
      }
    }
  ]
}
