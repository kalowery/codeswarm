{
  "ssh": {
    "login_alias": "your-login-alias"
  },
  "cluster": {
    "workspace_root": "/path/to/shared/workspace",
    "cluster_subdir": "codeswarm",
    "slurm": {
      "partition": "compute",
      "time_limit": "00:20:00",
      "account": null,
      "qos": null
    }
  },
  "router": {
    "inject_timeout_seconds": 60
  },
  "launch_providers": [
    {
      "id": "slurm-default",
      "label": "Slurm Default",
      "backend": "slurm"
    },
    {
      "id": "local-dev",
      "label": "Local Dev",
      "backend": "local"
    }
  ]
}
